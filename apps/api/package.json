    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@prisma/client": "^5.12.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.4.0",
    "fastify": "^4.27.0",
    "ioredis": "^5.3.2",
    "nodemailer": "^6.9.13",
    "otplib": "^12.0.1",
    "stripe": "^15.4.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
