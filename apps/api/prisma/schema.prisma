generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("DATABASE_SHADOW_URL")
}

// ─── SCHEMA GLOBAL (public) ───────────────────────────────────────

model Plan {
  id            String   @id @default(uuid())
  nombre        String
  precioMensual Decimal  @map("precio_mensual") @db.Decimal(12, 2)
  precioAnual   Decimal? @map("precio_anual")   @db.Decimal(12, 2)
  maxUsuarios   Int      @map("max_usuarios")
  maxStorageGb  Int      @map("max_storage_gb")
  modulosIds    String[] @map("modulos_ids")
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  suscriptores  Suscriptor[]
  @@map("planes")
}

model Modulo {
  id           String   @id @default(uuid())
  nombre       String
  descripcion  String?
  version      String   @default("1.0.0")
  activo       Boolean  @default(true)
  dependencias String[] @default([])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  @@map("modulos")
}

model Suscriptor {
  id            String            @id @default(uuid())
  nombre        String
  rut           String            @unique
  rubro         String?
  planId        String            @map("plan_id")
  plan          Plan              @relation(fields: [planId], references: [id])
  modulosActivos String[]         @map("modulos_activos") @default([])
  estado        EstadoSuscriptor  @default(TRIAL)
  schemaName    String            @unique @map("schema_name")
  fechaInicio   DateTime          @map("fecha_inicio") @default(now())
  fechaExpiracion DateTime?       @map("fecha_expiracion")
  config        Json              @default("{}")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  facturas      Factura[]
  auditorias    Auditoria[]
  @@map("suscriptores")
}

model Factura {
  id             String         @id @default(uuid())
  suscriptorId   String         @map("suscriptor_id")
  suscriptor     Suscriptor     @relation(fields: [suscriptorId], references: [id])
  periodo        String
  monto          Decimal        @db.Decimal(12, 2)
  estado         EstadoFactura  @default(PENDIENTE)
  metodoPago     String?        @map("metodo_pago")
  stripeInvoiceId String?       @map("stripe_invoice_id")
  fechaVencimiento DateTime     @map("fecha_vencimiento")
  fechaPago       DateTime?     @map("fecha_pago")
  createdAt       DateTime      @default(now()) @map("created_at")
  @@map("facturas")
}

model Auditoria {
  id           String     @id @default(uuid())
  suscriptorId String?    @map("suscriptor_id")
  suscriptor   Suscriptor? @relation(fields: [suscriptorId], references: [id])
  usuarioId    String?    @map("usuario_id")
  accion       String
  entidad      String
  entidadId    String?    @map("entidad_id")
  metadata     Json       @default("{}")
  ip           String?
  userAgent    String?    @map("user_agent")
  createdAt    DateTime   @default(now()) @map("created_at")
  @@map("auditorias")
  @@index([suscriptorId, createdAt])
  @@index([usuarioId])
}

enum EstadoSuscriptor {
  TRIAL
  ACTIVO
  SUSPENDIDO
  CANCELADO
}

enum EstadoFactura {
  PENDIENTE
  PAGADO
  VENCIDO
  ANULADO
}
